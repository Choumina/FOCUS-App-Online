{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Stores user progress, settings, and status.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "points": { "type": "integer", "description": "User's current points" },
        "level": { "type": "integer", "description": "User's current level" },
        "rank": { "type": "integer", "description": "User's current ranking" },
        "petCount": { "type": "integer", "description": "Number of pets owned" },
        "userProfile": { "type": "object", "description": "Full user profile object" },
        "hasCompletedOnboarding": { "type": "boolean", "description": "Whether the user has seen the guide" },
        "hasCompletedTour": { "type": "boolean", "description": "Whether the user has seen the feature tour" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "User profile documents"
    }
  }
}
